OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_CHAT_MODEL=gpt-oss:120b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=landchain_rag
MILVUS_METRIC=COSINE
DATA_DIR=./data
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
RETRIEVE_K=12
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SESSION_DB_PATH=./storage/sessions.db
MAX_UPLOAD_SIZE_MB=20
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# MongoDB（仅存 chunk 原文 + 元数据，不存向量）
MONGODB_ENABLED=true
MONGO_ROOT_USERNAME=landchain
MONGO_ROOT_PASSWORD=landchain
MONGO_DATABASE=landchain
MONGODB_URI=mongodb://landchain:landchain@localhost:27017/landchain?authSource=admin
MONGODB_DOCUMENTS_COLLECTION=documents
MONGODB_CHUNKS_COLLECTION=document_chunks

# 闲聊/问候直连模型，不走 RAG 检索
CHITCHAT_DIRECT_ENABLED=true
CHITCHAT_MAX_LENGTH=24

# Agent 超级智能体
AGENT_ENABLED=true
AGENT_SESSION_DB_PATH=./storage/agent_sessions.db
AGENT_AUDIT_DB_PATH=./storage/agent_audit.db
AGENT_MAX_ITERATIONS=15
AGENT_TOOL_RESULT_MAX_CHARS=12000
OLLAMA_AGENT_MODEL=qwen3:8b
OLLAMA_AGENT_FALLBACK_MODEL=qwen3:8b
AGENT_SHELL_ENABLED=true
AGENT_SHELL_MODE=allowlist
AGENT_SHELL_TIMEOUT=30
AGENT_HITL_ENABLED=true
AGENT_API_KEY=
AGENT_TASKS_PATH=./storage/agent_tasks.yaml
AGENT_TIMEZONE=Asia/Shanghai
MONGODB_AGENT_COLLECTION_DENYLIST=documents,document_chunks,agent_runs,agent_audit
