OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_CHAT_MODEL=gpt-oss:120b-cloud

OLLAMA_EMBED_MODEL=nomic-embed-text

QDRANT_URL=http://localhost:6333

QDRANT_COLLECTION=landchain_rag_v2

QDRANT_API_KEY=

EMBED_MODEL=BAAI/bge-m3

EMBED_DEVICE=cpu

HYBRID_ENABLED=true

RRF_K=60

DATA_DIR=./data

CHUNK_SIZE=800

CHUNK_OVERLAP=120

TOP_K=4

RETRIEVE_K=24

RERANK_ENABLED=true

RERANK_MODEL=BAAI/bge-reranker-v2-m3

RERANK_MIN_SCORE=-2.0

QUERY_REWRITE_ENABLED=true

QUERY_REWRITE_TIMEOUT=2.0

NEIGHBOR_EXPAND_ENABLED=true

NEIGHBOR_WINDOW=1

EXPAND_MAX_CHUNKS=8

SESSION_DB_PATH=./storage/sessions.db

MAX_UPLOAD_SIZE_MB=20

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000



# PostgreSQL 业务 JSON 集合（如 order），供统计报告脚本与 Agent 读取

POSTGRES_HOST=localhost

POSTGRES_PORT=5432

POSTGRES_USER=landchain

POSTGRES_PASSWORD=landchain

POSTGRES_DB=landchain

POSTGRES_BUSINESS_COLLECTION=order

POSTGRES_BUSINESS_ID_FIELD=ID

POSTGRES_BUSINESS_TIME_FIELD=created_at



# 闲聊/问候直连模型，不走 RAG 检索

CHITCHAT_DIRECT_ENABLED=true

CHITCHAT_MAX_LENGTH=24



# Agent 超级智能体

AGENT_ENABLED=true

AGENT_SESSION_DB_PATH=./storage/agent_sessions.db

AGENT_AUDIT_DB_PATH=./storage/agent_audit.db

AGENT_MAX_ITERATIONS=15

AGENT_TOOL_RESULT_MAX_CHARS=12000

OLLAMA_AGENT_MODEL=

OLLAMA_AGENT_FALLBACK_MODEL=qwen2.5:14b

AGENT_SHELL_ENABLED=true

AGENT_SHELL_MODE=allowlist

AGENT_SHELL_TIMEOUT=30

AGENT_HITL_ENABLED=true

AGENT_API_KEY=

AGENT_TASKS_PATH=./storage/agent_tasks.yaml

AGENT_TIMEZONE=Asia/Shanghai

POSTGRES_AGENT_COLLECTION_DENYLIST=agent_runs,agent_audit


QDRANT_COLLECTION=landchain_rag_v2
EMBED_MODEL=BAAI/bge-m3
HYBRID_ENABLED=true
RETRIEVE_K=24
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MIN_SCORE=-2.0
QUERY_REWRITE_ENABLED=true
NEIGHBOR_EXPAND_ENABLED=true